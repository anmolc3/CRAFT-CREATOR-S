// ============================================================================
// CRAFT CREATOR'S — Custom Photo Framing Studio
// Prisma Schema
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Admin ───────────────────────────────────────────────────────────────────
model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

// ─── Frame Category ───────────────────────────────────────────────────────────
model FrameCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  imageUrl    String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  frames FrameDesign[]

  @@map("frame_categories")
}

// ─── Frame Material ───────────────────────────────────────────────────────────
model FrameMaterial {
  id          String   @id @default(cuid())
  name        String   @unique  // Wood | Metal | Composite
  description String?
  priceAdder  Int      @default(0) // Additional cost
  order       Int      @default(0)

  frames FrameDesign[]

  @@map("frame_materials")
}

// ─── Frame Color ──────────────────────────────────────────────────────────────
model FrameColor {
  id        String   @id @default(cuid())
  name      String   @unique  // Black, White, Oak, Walnut, Gold, Silver, Cherry
  hex       String   @default("#000000")
  order     Int      @default(0)

  @@map("frame_colors")
}

// ─── Frame Size ───────────────────────────────────────────────────────────────
model FrameSize {
  id        String  @id @default(cuid())
  label     String  @unique // "8×10", "12×18", "16×24", "24×36", "Custom"
  width     Int     // inches
  height    Int     // inches
  basePrice Int     @default(1500) // in INR
  isCustom  Boolean @default(false)
  order     Int     @default(0)

  @@map("frame_sizes")
}

// ─── Glass Option ─────────────────────────────────────────────────────────────
model GlassOption {
  id          String @id @default(cuid())
  name        String @unique // Standard, Anti-Glare, UV-Protection
  description String?
  price       Int    @default(0)
  order       Int    @default(0)

  @@map("glass_options")
}

// ─── Mount Option ─────────────────────────────────────────────────────────────
model MountOption {
  id          String @id @default(cuid())
  name        String @unique // With Mount, Without Mount
  description String?
  price       Int    @default(0)
  order       Int    @default(0)

  @@map("mount_options")
}

// ─── Frame Design ─────────────────────────────────────────────────────────────
model FrameDesign {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  description       String?  @db.Text
  imageUrl          String   // Primary product image
  galleryImages     String[] // Additional images
  material          String   // Wood | Metal | Composite
  colors            String[] // Available colors
  availableSizes    String[] // Size labels available for this frame
  thickness         String   @default("2cm") // Frame thickness/width
  basePrice         Int      @default(2500)  // Starting price in INR
  productionDays    Int      @default(3)     // Estimated days to produce
  featured          Boolean  @default(false)
  bestseller        Boolean  @default(false)
  isAvailable       Boolean  @default(true)
  categoryId        String?
  order             Int      @default(0)
  views             Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  category  FrameCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  reviews   FrameReview[]
  analytics Analytics[]

  @@map("frame_designs")
}

// ─── Frame Review ─────────────────────────────────────────────────────────────
model FrameReview {
  id          String   @id @default(cuid())
  frameId     String
  customerName String
  rating      Int      @default(5)
  comment     String   @db.Text
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())

  frame FrameDesign @relation(fields: [frameId], references: [id], onDelete: Cascade)

  @@map("frame_reviews")
}

// ─── Customer Inquiry ─────────────────────────────────────────────────────────
model Inquiry {
  id              String   @id @default(cuid())
  // Customer Info
  customerName    String
  email           String
  phone           String
  whatsapp        String?
  // Order Details
  frameName       String?
  frameId         String?
  material        String?
  color           String?
  size            String?
  customWidth     Int?     // inches, if custom size
  customHeight    Int?     // inches, if custom size
  glass           String?
  mount           String?
  quantity        Int      @default(1)
  // Photo
  photoOption     String   @default("upload") // "upload" | "bring"
  uploadedImageUrl String?
  // Status & Admin
  status          String   @default("pending") // pending | confirmed | in_progress | completed | cancelled
  notes           String?  @db.Text
  totalEstimate   Int?     // Admin-filled estimated total in INR
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("inquiries")
}

// ─── Service ──────────────────────────────────────────────────────────────────
model Service {
  id          String   @id @default(cuid())
  title       String   @unique
  slug        String   @unique
  description String   @db.Text
  overview    String?  @db.Text
  includes    Json?    // Array of feature strings
  startingPrice Int    @default(0)
  duration    String?  // e.g. "3–5 working days"
  heroImage   String?
  gallery     Json?    // Array of image URLs
  faqs        Json?    // Array of { question, answer }
  featured    Boolean  @default(false)
  status      String   @default("active") // active | inactive
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("services")
}

// ─── Testimonial ──────────────────────────────────────────────────────────────
model Testimonial {
  id        String   @id @default(cuid())
  name      String
  title     String?  // e.g. "Interior Designer, Delhi"
  quote     String   @db.Text
  rating    Int      @default(5)
  photoUrl  String?
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("testimonials")
}

// ─── Newsletter ───────────────────────────────────────────────────────────────
model Newsletter {
  id           String   @id @default(cuid())
  email        String   @unique
  subscribedAt DateTime @default(now())

  @@map("newsletters")
}

// ─── Settings ─────────────────────────────────────────────────────────────────
model Settings {
  id                String  @id @default(cuid())
  businessName      String  @default("Craft Creator's")
  tagline           String  @default("Custom Photo Framing, Crafted with Precision")
  whatsappNumber    String  @default("918077037277")
  phone             String  @default("+91 80770 37277")
  email             String  @default("hello@craftcreators.in")
  address           String  @default("Mumbai, Maharashtra, India")
  instagramUrl      String  @default("https://www.instagram.com/craft_creators_original")
  facebookUrl       String  @default("https://facebook.com/craftcreators")
  youtubeUrl        String  @default("https://youtube.com/@craftcreators")
  heroTitle         String  @default("Frame Your Memories,\nForever")
  heroSubtitle      String  @default("Premium custom photo framing — your photographs, our craftsmanship")
  heroImage         String?
  aboutText         String  @default("Craft Creator's is a premium custom photo framing studio dedicated to preserving your most cherished memories in frames of exceptional quality.")
  seoTitle          String  @default("Craft Creator's | Premium Custom Photo Framing Studio")
  seoDescription    String  @default("Premium custom photo framing in Mumbai. Upload your photo or bring a printed copy. Choose from 40+ frame styles. Order via WhatsApp.")

  @@map("settings")
}

// ─── Analytics ────────────────────────────────────────────────────────────────
model Analytics {
  id        String   @id @default(cuid())
  event     String   // "frame_view" | "whatsapp_click" | "configurator_start" | "inquiry_submit"
  frameId   String?
  meta      String?  // JSON string for additional data
  createdAt DateTime @default(now())

  frame FrameDesign? @relation(fields: [frameId], references: [id], onDelete: SetNull)

  @@map("analytics")
}
